---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Enfoque from "../components/Enfoque.astro";
import Areas from "../components/Areas.astro";
import Steps from "../components/Steps.astro";
import Faq from "../components/Faq.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import { site, areas, faqs } from "../data/site";

const title = `${site.nombre} | Psicóloga en Córdoba - Presencial y online`;
const description =
  "Psicóloga en Córdoba. Terapia presencial y online para ansiedad, depresión, autoestima, pareja y duelo. Pide cita por WhatsApp, sin compromiso.";

// JSON-LD: ficha de negocio local para SEO (Google rich results / mapa de conocimiento).
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Psychologist",
  name: site.nombre,
  description,
  url: site.dominio,
  image: `${site.dominio}/images/clara.jpeg`,
  telephone: `+${site.whatsapp}`,
  email: site.email,
  // address y geo solo se incluyen cuando hay consulta fisica (ver site.ts).
  // Hasta entonces, la zona de servicio se expresa con areaServed.
  ...(site.direccion.calle
    ? {
        address: {
          "@type": "PostalAddress",
          streetAddress: site.direccion.calle,
          postalCode: site.direccion.cp,
          addressLocality: site.direccion.ciudad,
          addressRegion: site.direccion.region,
          addressCountry: site.direccion.pais,
        },
      }
    : {}),
  ...(site.geo.lat
    ? {
        geo: {
          "@type": "GeoCoordinates",
          latitude: site.geo.lat,
          longitude: site.geo.lng,
        },
      }
    : {}),
  areaServed: [
    { "@type": "City", name: "Córdoba" },
    { "@type": "Country", name: "España" },
  ],
  availableLanguage: ["es"],
  knowsAbout: areas.flatMap((a) => a.items),
  ...(site.sameAs.length > 0 ? { sameAs: site.sameAs } : {}),
};

// FAQPage: permite que las preguntas aparezcan enriquecidas en Google.
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};

const graph = { "@context": "https://schema.org", "@graph": [jsonLd, faqLd] };
---

<Base title={title} description={description} path="/" jsonLd={graph}>
  <Nav />
  <main>
    <Hero />
    <Enfoque />
    <Areas />
    <Steps />
    <Faq />
    <Contact />
  </main>
  <Footer />
</Base>
