---
import { site } from "../data/site";
import WhatsAppButton from "./WhatsAppButton.astro";

const links = [
  { href: "#sobre-mi", label: "Sobre mí" },
  { href: "#areas", label: "Áreas" },
  { href: "#como-trabajo", label: "Cómo trabajo" },
  { href: "#preguntas", label: "Preguntas" },
];
---

<header class="nav">
  <div class="container row">
    <a href="#inicio" class="brand">
      <span class="mark" aria-hidden="true">
        <svg viewBox="0 0 32 32">
          <circle cx="16" cy="16" r="15" fill="currentColor"></circle>
          <text
            x="16"
            y="22"
            text-anchor="middle"
            fill="#f7f4ee"
            font-family="Instrument Serif, Georgia, serif"
            font-size="18"
            font-style="italic">C</text
          >
        </svg>
      </span>
      <span class="name">{site.nombre}</span>
    </a>

    <nav class="links" aria-label="Navegación principal">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="cta">
      <WhatsAppButton label="Pedir cita" />
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    height: var(--nav-h);
    display: flex;
    align-items: center;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }

  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: min(var(--max-width), 100% - var(--gutter) * 2);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    color: var(--text);
    min-width: 0;
  }
  .mark {
    color: var(--accent);
    width: 30px;
    height: 30px;
    flex-shrink: 0;
  }
  .name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    line-height: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .links {
    display: none;
    gap: 1.5rem;
    font-size: 0.95rem;
  }
  .links a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 180ms ease;
  }
  .links a:hover {
    color: var(--accent);
  }

  /* CTA siempre visible; en movil queda compacto */
  .cta {
    flex-shrink: 0;
  }

  @media (min-width: 880px) {
    .links {
      display: flex;
    }
  }

  /* En pantallas estrechas ocultamos el nombre largo para dejar sitio al CTA */
  @media (max-width: 520px) {
    .name {
      display: none;
    }
  }
</style>
