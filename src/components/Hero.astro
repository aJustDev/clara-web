---
import { site } from "../data/site";
import WhatsAppButton from "./WhatsAppButton.astro";
---

<section id="inicio" class="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <span class="badge">
        <span class="badge-dot" aria-hidden="true"></span>
        Psicóloga en Córdoba - Presencial y online
      </span>
      <h1 class="headline">
        Volver a lo que <em>importa</em>
      </h1>
      <p class="sub">
        Te doy la bienvenida a este espacio. Soy Clara (colegiada
        n.º&nbsp;{site.numColegiada}), y he tenido el gran privilegio de
        acompañar a muchas personas en su proceso de cambio a lo largo de mi
        trayectoria como psicóloga. Un camino precioso lleno de retos y
        aprendizajes.
      </p>
      <div class="cta-row">
        <WhatsAppButton label="Pedir cita" size="lg" />
        <span class="cta-microcopy">Te respondo personalmente, sin compromiso.</span>
      </div>
    </div>

    <div class="hero-photo">
      <img
        src={`${import.meta.env.BASE_URL}/images/clara.jpeg`}
        alt={`${site.nombre}, psicóloga en Córdoba`}
        width="1071"
        height="1428"
        fetchpriority="high"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: clamp(2.5rem, 7vw, 4.5rem);
    padding-bottom: var(--section-py);
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  @media (min-width: 880px) {
    .hero-grid {
      grid-template-columns: 1.25fr 1fr;
      gap: 3.5rem;
    }
  }

  .hero-copy {
    animation: fade-up 600ms ease-out both;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    margin-bottom: 1.75rem;
  }
  .badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 rgba(91, 122, 90, 0.45);
    animation: pulse 2.4s ease-out infinite;
  }

  .headline {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.6rem, 6.5vw, 4.6rem);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--text);
    margin: 0 0 1.5rem;
    max-width: 16ch;
  }
  .headline em {
    font-style: italic;
    color: var(--accent);
  }

  .sub {
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    color: var(--text-muted);
    max-width: 52ch;
    margin: 0 0 2rem;
  }

  .cta-row {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    align-items: flex-start;
  }
  .cta-microcopy {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .hero-photo {
    justify-self: center;
    width: 100%;
    max-width: 420px;
  }
  .hero-photo img {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-md);
    background: var(--accent-soft);
  }

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(91, 122, 90, 0.45);
    }
    70% {
      box-shadow: 0 0 0 8px rgba(91, 122, 90, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(91, 122, 90, 0);
    }
  }
</style>
