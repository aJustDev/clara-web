---
import { areas } from "../data/site";
---

<section id="areas" class="areas" aria-labelledby="areas-title">
  <div class="container">
    <h2 id="areas-title" class="section-title">En qué puedo ayudarte</h2>
    <p class="section-sub">
      Algunos de los motivos por los que las personas acuden a terapia. Si lo
      tuyo no está aquí, escríbeme y lo vemos.
    </p>
    <div class="grid">
      {
        areas.map((a) => (
          <article class="card">
            <div class="icon" aria-hidden="true">
              {a.icon === "sprout" && (
                <svg viewBox="0 0 32 32" fill="none">
                  <path d="M16 28 V14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                  <path d="M16 18 C16 13 12 10 7 10 C7 15 11 18 16 18 Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                  <path d="M16 15 C16 10 20 7 25 7 C25 12 21 15 16 15 Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                </svg>
              )}
              {a.icon === "heart" && (
                <svg viewBox="0 0 32 32" fill="none">
                  <path d="M16 27 C7 21 4 16 4 11.5 A5.5 5.5 0 0 1 14.5 9.5 L16 12 L17.5 9.5 A5.5 5.5 0 0 1 28 11.5 C28 16 25 21 16 27 Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                </svg>
              )}
              {a.icon === "spark" && (
                <svg viewBox="0 0 32 32" fill="none">
                  <path d="M16 4 L18.5 13.5 L28 16 L18.5 18.5 L16 28 L13.5 18.5 L4 16 L13.5 13.5 Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                </svg>
              )}
              {a.icon === "cloud" && (
                <svg viewBox="0 0 32 32" fill="none">
                  <path d="M9 22 A5 5 0 0 1 9.5 12 A7 7 0 0 1 23 13 A4.5 4.5 0 0 1 23 22 Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                </svg>
              )}
              {a.icon === "link" && (
                <svg viewBox="0 0 32 32" fill="none">
                  <path d="M13 19 L19 13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                  <path d="M18 9 L20 7 A5 5 0 0 1 27 14 L25 16" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M14 23 L12 25 A5 5 0 0 1 5 18 L7 16" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )}
              {a.icon === "compass" && (
                <svg viewBox="0 0 32 32" fill="none">
                  <circle cx="16" cy="16" r="12" stroke="currentColor" stroke-width="1.4" />
                  <path d="M21 11 L17.5 17.5 L11 21 L14.5 14.5 Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                </svg>
              )}
            </div>
            <h3 class="card-title">{a.title}</h3>
            <ul class="card-list">
              {a.items.map((it) => (
                <li>{it}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .areas {
    padding-block: var(--section-py);
    background: linear-gradient(180deg, transparent 0, rgba(91, 122, 90, 0.04) 100%);
  }

  .section-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    color: var(--text);
    margin: 0 0 0.75rem;
    text-align: center;
    letter-spacing: -0.005em;
  }
  .section-sub {
    color: var(--text-muted);
    text-align: center;
    max-width: 52ch;
    margin: 0 auto 2.5rem;
    font-size: 1rem;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }
  @media (min-width: 960px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
    transition:
      transform 220ms ease,
      box-shadow 220ms ease,
      border-color 220ms ease;
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
    border-color: var(--border-strong);
  }

  .icon {
    width: 44px;
    height: 44px;
    color: var(--accent);
    margin-bottom: 1.25rem;
    background: var(--accent-soft);
    border-radius: var(--radius-sm);
    display: grid;
    place-items: center;
    padding: 9px;
  }
  .icon svg {
    width: 100%;
    height: 100%;
  }

  .card-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.4rem;
    color: var(--text);
    margin: 0 0 0.5rem;
    letter-spacing: -0.005em;
  }
  .card-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.45rem;
  }
  .card-list li {
    position: relative;
    padding-left: 1rem;
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.5;
  }
  .card-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
  }
</style>
