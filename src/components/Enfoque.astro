---
import { site } from "../data/site";
---

<section id="enfoque" class="enfoque" aria-labelledby="enfoque-title">
  <div class="container grid">
    <div class="media">
      <img
        src={`${import.meta.env.BASE_URL}/images/clara_despacho.jpeg`}
        alt={`${site.nombre} en su consulta de psicología en Córdoba`}
        width="1071"
        height="1428"
        loading="lazy"
      />
    </div>

    <div class="copy">
      <h2 id="enfoque-title" class="section-title">Mi enfoque terapéutico</h2>
      <p>
        Trabajo bajo el marco del conductismo y de las terapias contextuales, en
        particular de la Terapia de Aceptación y Compromiso (ACT), por ser el
        enfoque con mayor evidencia científica.
      </p>

      <ul class="facts">
        <li><span aria-hidden="true">&#9670;</span> Terapia presencial en Córdoba y online</li>
        <li><span aria-hidden="true">&#9670;</span> Sesiones individuales y de pareja</li>
        <li><span aria-hidden="true">&#9670;</span> Psicóloga colegiada n.º&nbsp;{site.numColegiada}</li>
      </ul>
    </div>
  </div>
</section>

<style>
  .enfoque {
    padding-block: var(--section-py);
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  @media (min-width: 880px) {
    .grid {
      grid-template-columns: 0.8fr 1.2fr;
      gap: 3.5rem;
    }
    .media {
      order: 0; /* escritorio: la foto vuelve a la izquierda */
    }
  }

  .media {
    justify-self: center;
    width: 100%;
    max-width: 300px;
    order: 1; /* movil: la foto va debajo del texto */
  }
  .media img {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    background: var(--accent-soft);
  }

  .section-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    color: var(--text);
    margin: 0 0 1.25rem;
    letter-spacing: -0.005em;
  }

  .copy p {
    color: var(--text-muted);
    margin: 0 0 1rem;
    max-width: 56ch;
  }

  .facts {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }
  .facts li {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    color: var(--text);
    font-size: 0.95rem;
  }
  .facts span {
    color: var(--accent);
    font-size: 0.7rem;
    flex-shrink: 0;
  }
</style>
